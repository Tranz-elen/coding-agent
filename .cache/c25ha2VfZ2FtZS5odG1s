<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>贪吃蛇小游戏</title>
    <link rel="stylesheet" href="snake_game.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <div class="game-container">
        <header class="game-header">
            <h1><i class="fas fa-gamepad"></i> 贪吃蛇小游戏</h1>
            <p class="game-description">使用方向键或WASD控制蛇的移动，吃到食物增长身体，不要撞到墙壁或自己！</p>
        </header>
        
        <main class="game-main">
            <div class="game-info">
                <div class="score-board">
                    <div class="score-item">
                        <i class="fas fa-star"></i>
                        <span>分数: <span id="score">0</span></span>
                    </div>
                    <div class="score-item">
                        <i class="fas fa-tachometer-alt"></i>
                        <span>速度: <span id="speed">1</span></span>
                    </div>
                    <div class="score-item">
                        <i class="fas fa-ruler"></i>
                        <span>长度: <span id="length">3</span></span>
                    </div>
                    <div class="score-item">
                        <i class="fas fa-trophy"></i>
                        <span>难度: <span id="difficulty">普通</span></span>
                    </div>
                    <div class="score-item">
                        <i class="fas fa-crown"></i>
                        <span>最高分: <span id="high-score">0</span></span>
                    </div>
                </div>
                
                <div class="controls">
                    <button id="start-btn" class="btn btn-primary">
                        <i class="fas fa-play"></i> 开始游戏
                    </button>
                    <button id="pause-btn" class="btn btn-secondary">
                        <i class="fas fa-pause"></i> 暂停
                    </button>
                    <button id="reset-btn" class="btn btn-danger">
                        <i class="fas fa-redo"></i> 重新开始
                    </button>
                    <button id="sound-btn" class="btn btn-sound">
                        <i class="fas fa-volume-up"></i> 音效
                    </button>
                    <button id="reset-highscore-btn" class="btn btn-warning">
                        <i class="fas fa-trash-alt"></i> 重置记录
                    </button>
                    <button id="reset-stats-btn" class="btn btn-info">
                        <i class="fas fa-chart-line"></i> 重置统计
                    </button>
                    <button id="theme-toggle-btn" class="btn btn-theme">
                        <i class="fas fa-palette"></i> 主题
                    </button>
                    <div class="difficulty-selector">
                        <select id="difficulty-select">
                            <option value="easy">简单</option>
                            <option value="normal" selected>普通</option>
                            <option value="hard">困难</option>
                            <option value="expert">专家</option>
                        </select>
                    </div>
                </div>
            </div>
            
            <div class="game-area">
                <canvas id="game-canvas" width="600" height="400"></canvas>
                <div class="game-overlay" id="game-overlay">
                    <div class="overlay-content">
                        <h2 id="overlay-title">贪吃蛇游戏</h2>
                        <p id="overlay-text">点击"开始游戏"按钮开始</p>
                        <div class="instructions">
                            <h3><i class="fas fa-info-circle"></i> 游戏说明</h3>
                            <ul>
                                <li><i class="fas fa-arrow-up"></i> 方向键或WASD控制移动</li>
                                <li><i class="fas fa-apple-alt"></i> 吃到红色食物增长身体</li>
                                <li><i class="fas fa-skull-crossbones"></i> 不要撞墙或撞到自己</li>
                                <li><i class="fas fa-tachometer-alt"></i> 每得10分速度增加</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="keyboard-controls">
                <h3><i class="fas fa-keyboard"></i> 键盘控制</h3>
                <div class="key-grid">
                    <div class="key-row">
                        <div class="key" data-key="W">W</div>
                        <div class="key" data-key="↑">↑</div>
                    </div>
                    <div class="key-row">
                        <div class="key" data-key="A">A</div>
                        <div class="key" data-key="S">S</div>
                        <div class="key" data-key="D">D</div>
                    </div>
                    <div class="key-row">
                        <div class="key" data-key="←">←</div>
                        <div class="key" data-key="↓">↓</div>
                        <div class="key" data-key="→">→</div>
                    </div>
                </div>
            </div>
            
            <div class="game-stats">
                <h3><i class="fas fa-chart-bar"></i> 游戏统计</h3>
                <div class="stats-grid">
                    <div class="stat-item">
                        <div class="stat-label">总游戏次数</div>
                        <div class="stat-value" id="total-games">0</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-label">总得分</div>
                        <div class="stat-value" id="total-score">0</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-label">平均分数</div>
                        <div class="stat-value" id="average-score">0</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-label">最长蛇身</div>
                        <div class="stat-value" id="max-length">0</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-label">特殊食物</div>
                        <div class="stat-value" id="special-food-count">0</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-label">游戏时间</div>
                        <div class="stat-value" id="total-time">0s</div>
                    </div>
                </div>
            </div>
        </main>
        
        <footer class="game-footer">
            <p>© 2024 贪吃蛇小游戏 | 使用HTML5 Canvas制作</p>
        </footer>
    </div>
    
    <script>
        // 解决本地文件访问的安全限制
        if (window.location.protocol === 'file:') {
            console.log('检测到本地文件访问，启用兼容模式');
            
            // 添加一个简单的错误处理
            window.addEventListener('error', function(e) {
                console.log('JavaScript错误:', e.message);
            });
            
            // 解决跨域问题
            document.addEventListener('DOMContentLoaded', function() {
                console.log('DOM已加载，准备初始化游戏');
            });
        }
    </script>
    <script src="snake_game_utf8.js"></script>
</body>
</html>