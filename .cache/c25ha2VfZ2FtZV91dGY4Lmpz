// 绘制障碍物
function drawObstacles() {
    for (const obstacle of gameState.obstacles) {
        const obstacleConfig = OBSTACLES[obstacle.type];
        if (!obstacleConfig) continue;
        
        const x = obstacle.x * CONFIG.GRID_SIZE;
        const y = obstacle.y * CONFIG.GRID_SIZE;
        const size = CONFIG.GRID_SIZE;
        
        // 绘制障碍物主体
        ctx.fillStyle = obstacleConfig.color;
        ctx.fillRect(x, y, size, size);
        
        // 根据障碍物类型绘制不同图案
        ctx.strokeStyle = '#000000';
        ctx.lineWidth = 1;
        
        switch (obstacleConfig.pattern) {
            case 'spike':
                // 绘制尖刺图案
                ctx.beginPath();
                for (let i = 0; i < 4; i++) {
                    const angle = (Math.PI / 2) * i;
                    const spikeX = x + size/2 + Math.cos(angle) * size/3;
                    const spikeY = y + size/2 + Math.sin(angle) * size/3;
                    ctx.moveTo(x + size/2, y + size/2);
                    ctx.lineTo(spikeX, spikeY);
                }
                ctx.stroke();
                break;
                
            case 'wall':
                // 绘制砖墙图案
                ctx.strokeStyle = '#2c3e50';
                ctx.lineWidth = 2;
                ctx.strokeRect(x + 2, y + 2, size - 4, size - 4);
                
                // 绘制砖缝
                ctx.beginPath();
                ctx.moveTo(x + size/2, y + 2);
                ctx.lineTo(x + size/2, y + size - 2);
                ctx.moveTo(x + 2, y + size/2);
                ctx.lineTo(x + size - 2, y + size/2);
                ctx.stroke();
                break;
                
            case 'solid':
            default:
                // 绘制岩石纹理
                ctx.strokeStyle = '#95a5a6';
                ctx.lineWidth = 2;
                ctx.strokeRect(x + 2, y + 2, size - 4, size - 4);
                
                // 绘制一些随机纹理点
                for (let i = 0; i < 5; i++) {
                    const dotX = x + 4 + Math.random() * (size - 8);
                    const dotY = y + 4 + Math.random() * (size - 8);
                    const dotSize = Math.random() * 2 + 1;
                    
                    ctx.fillStyle = '#bdc3c7';
                    ctx.beginPath();
                    ctx.arc(dotX, dotY, dotSize, 0, Math.PI * 2);
                    ctx.fill();
                }
                break;
        }
        
        // 添加阴影效果
        ctx.shadowColor = 'rgba(0, 0, 0, 0.5)';
        ctx.shadowBlur = 5;
        ctx.shadowOffsetX = 2;
        ctx.shadowOffsetY = 2;
        
        // 绘制完成后重置阴影
        setTimeout(() => {
            ctx.shadowColor = 'transparent';
            ctx.shadowBlur = 0;
            ctx.shadowOffsetX = 0;
            ctx.shadowOffsetY = 0;
        }, 0);
    }
}
